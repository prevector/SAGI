{
  "name": "sagi-mvp",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @sagi/shared && npm run build -w @sagi/evolution && npm run build -w @sagi/api && npm run build -w @sagi/web",
    "dev": "npm-run-all --parallel dev:*",
    "dev:api": "npm run dev -w @sagi/api",
    "dev:web": "npm run dev -w @sagi/web",
    "experiment:iaf": "tsx experiments/enu_iaf_benchmark.ts",
    "experiment:iaf:reproduce": "tsx experiments/enu_iaf_reproduction.ts",
    "start": "NODE_ENV=production node apps/api/dist/server.js",
    "release": "bash ./scripts/release.sh"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
