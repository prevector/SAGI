{
  "name": "sagi-mvp",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm-run-all --parallel dev:*",
    "dev:api": "npm run dev -w @sagi/api",
    "dev:web": "npm run dev -w @sagi/web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2"
  }
}
