PORT=4000
SESSION_SECRET=change-me
SECURE_COOKIES=1

# --- Token economy (apps/api ledger) ---
# Mode selects active tx sources: demo (seeded synthetic + live user),
# sandbox (real only, ephemeral), production (real only, synthetic purged).
# Default: demo in dev, production when NODE_ENV=production.
LEDGER_MODE=demo
# Reproducible demo fixtures: same seed => identical synthetic world.
LEDGER_SEED=1337
# SQLite file (":memory:" for sandbox/tests). Under runs/ (git-ignored).
LEDGER_DB_PATH=runs/ledger.db
# Optional emission overrides (defaults: E0=1050000 SAGI, r=0.95 => 21M cap).
# LEDGER_E0=1050000
# LEDGER_R=0.95
# Epoch length in ms (default: 10000 demo, 3600000 otherwise).
# LEDGER_EPOCH_MS=10000
# Demo genesis size.
# LEDGER_GENESIS_USERS=12
# LEDGER_GENESIS_DAYS=30

# Frontend (apps/web): set to 1 to use the pure-frontend mock instead of the API.
# VITE_USE_MOCK=1

MOLLIE_API_KEY=test_DpHh4b3FFfwVN5EadWHv4nywJVASew # test purposes
# APP_URL=http://localhost:5173   # only if not on that default